    "alerts": {
      "minimum_state_duration_seconds": 30,
      "cooldown_seconds": 90,
      "recovery_score_healthy": 93,
      "recovery_score_degraded": 78,
      "recovery_score_unstable": 45
    },
    "retention": {
      "health_snapshot_days": 14,
      "health_snapshot_max_rows": 50000,
      "prune_every_seconds": 21600
