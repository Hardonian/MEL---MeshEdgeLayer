  "intelligence": {
    "scoring": {
      "anomaly_windows_seconds": [
        60,
        300,
        900
      ],
      "reason_weights": {
        "decode_failure": 5,
        "handler_rejection": 6,
        "malformed_frame": 5,
        "malformed_publish": 5,
        "rejected_publish": 6,
        "rejected_send": 6,
        "retry_threshold_exceeded": 30,
        "stream_failure": 8,
        "subscribe_failure": 8,
        "timeout_failure": 10,
        "timeout_stall": 5,
        "topic_mismatch": 3
      },
      "dead_letter_penalty": 25,
      "historical_dead_letter_weight": 5,
      "residual_penalty_cap": 15,
      "active_episode_penalty": 5,
      "active_episode_penalty_cap": 25,
      "observation_drop_base_penalty": 6,
      "observation_drop_step_penalty": 3,
      "observation_drop_penalty_cap": 30,
      "runtime_retrying_penalty": 12,
      "runtime_failed_penalty": 20,
      "heartbeat_penalty_120_seconds": 10,
      "heartbeat_penalty_300_seconds": 20,
      "heartbeat_penalty_900_seconds": 30
