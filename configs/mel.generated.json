    "queries": {
      "default_limit": 50,
      "max_limit": 500
    }
  },
  "control": {
    "mode": "advisory",
    "emergency_disable": false,
    "allowed_actions": [
      "restart_transport",
      "resubscribe_transport",
      "backoff_increase",
      "backoff_reset",
      "temporarily_deprioritize_transport",
      "temporarily_suppress_noisy_source",
      "clear_suppression",
      "trigger_health_recheck"
