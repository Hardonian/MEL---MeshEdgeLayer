{
  "bind": {
    "api": "127.0.0.1:8080",
    "metrics": "",
    "allow_remote": false
  },
  "auth": {
    "enabled": false,
    "session_secret": "replace-with-32-byte-secret",
    "ui_user": "admin",
    "ui_password": "change-me",
    "allow_insecure_remote": false
  },
  "storage": {
    "data_dir": "./data",
    "database_path": "./data/mel.db",
    "encryption_key_env": "MEL_STORAGE_KEY",
    "encryption_required": false
  },
  "logging": {
    "level": "info",
    "format": "json"
  },
  "retention": {
    "messages_days": 30,
    "telemetry_days": 30,
    "audit_days": 90,
    "precise_position_days": 7
  },
  "privacy": {
    "store_precise_positions": false,
    "mqtt_encryption_required": true,
    "map_reporting_allowed": false,
    "redact_exports": true,
    "trust_list": []
  },
  "transports": [
    {
      "name": "pi-radio",
      "type": "serial",
      "enabled": true,
      "serial_device": "/dev/ttyUSB0",
      "serial_baud": 115200,
      "reconnect_seconds": 5,
      "notes": "Preferred direct-node deployment for Raspberry Pi and Linux hosts."
    },
    {
      "name": "lab-radio-tcp",
      "type": "tcp",
      "enabled": false,
      "tcp_host": "127.0.0.1",
      "tcp_port": 4403,
      "reconnect_seconds": 5,
      "notes": "Use only when a Meshtastic-compatible TCP stream endpoint is actually present."
    },
    {
      "name": "local-mqtt",
      "type": "mqtt",
      "enabled": false,
      "endpoint": "127.0.0.1:1883",
      "topic": "msh/US/2/e/#",
      "client_id": "mel-local",
      "notes": "Optional MQTT ingest path. Keep disabled for direct-node-first deployments unless you need hybrid ingest."
    }
  ],
  "features": {
    "web_ui": true,
    "metrics": false,
    "ble_experimental": false
  },
  "rate_limits": {
    "http_rps": 20,
    "transport_reconnect_seconds": 10
  }
}
