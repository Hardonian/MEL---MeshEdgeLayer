{
  "bind": {
    "api": "127.0.0.1:8080",
    "metrics": "",
    "allow_remote": false
  },
  "auth": {
    "enabled": false,
    "session_secret": "replace-with-32-byte-secret",
    "ui_user": "admin",
    "ui_password": "change-me",
    "allow_insecure_remote": false,
    "operator_keys": []
  },
  "storage": {
    "data_dir": "./data",
    "database_path": "./data/mel.db",
    "encryption_key_env": "MEL_STORAGE_KEY",
    "encryption_required": false
  },
  "logging": {
    "level": "info",
    "format": "json"
  },
  "retention": {
    "messages_days": 30,
    "telemetry_days": 30,
    "audit_days": 90,
    "precise_position_days": 7
  },
  "privacy": {
    "store_precise_positions": false,
    "mqtt_encryption_required": true,
    "map_reporting_allowed": false,
    "redact_exports": true,
    "trust_list": []
  },
  "transports": [
    {
      "name": "pi-radio",
      "type": "serial",
      "enabled": true,
      "serial_device": "/dev/ttyUSB0",
      "serial_baud": 115200,
      "reconnect_seconds": 5,
      "notes": "Preferred direct-node deployment for Raspberry Pi and Linux hosts. Inspect /api/v1/status for last_heartbeat_at and consecutive_timeouts runtime evidence.",
      "read_timeout_seconds": 15,
      "write_timeout_seconds": 5,
      "max_consecutive_timeouts": 3
    },
    {
      "name": "lab-radio-tcp",
      "type": "tcp",
      "enabled": false,
      "tcp_host": "127.0.0.1",
      "tcp_port": 4403,
      "reconnect_seconds": 5,
      "notes": "Use only when a Meshtastic-compatible TCP stream endpoint is actually present. Inspect /api/v1/status for last_heartbeat_at and consecutive_timeouts runtime evidence.",
      "read_timeout_seconds": 15,
      "write_timeout_seconds": 5,
      "max_consecutive_timeouts": 3
    },
    {
      "name": "local-mqtt",
      "type": "mqtt",
      "enabled": false,
      "endpoint": "127.0.0.1:1883",
      "topic": "msh/US/2/e/#",
      "client_id": "mel-local",
      "notes": "Optional MQTT ingest path. Keep disabled for direct-node-first deployments unless you need hybrid ingest. Inspect /api/v1/status for broker last_heartbeat_at, consecutive_timeouts, retry_status, and dead-letter evidence.",
      "read_timeout_seconds": 15,
      "write_timeout_seconds": 5,
      "max_consecutive_timeouts": 3,
      "mqtt_qos": 1,
      "mqtt_keepalive_seconds": 30
    }
  ],
  "features": {
    "web_ui": true,
    "metrics": false,
    "ble_experimental": false,
    "google_maps_in_topology_ui": false,
    "google_maps_api_key_env": ""
  },
  "rate_limits": {
    "http_rps": 20,
    "transport_reconnect_seconds": 10
  },
  "platform": {
    "mode": "self_hosted",
    "telemetry": {
      "enabled": false,
      "allow_outbound": false,
      "require_explicit_opt_in": true
    },
    "retention": {
      "default_days": 30,
      "allow_export": true,
      "allow_delete": true
    },
    "crypto": {
      "provider": "libsignal-compatible",
      "enabled": true,
      "required": true
    },
    "event_bus": {
      "provider": "nats-jetstream",
      "enabled": true,
      "endpoint": "nats://127.0.0.1:4222",
      "required": false
    },
    "blob_store": {
      "provider": "s3-compatible",
      "enabled": false,
      "endpoint": "http://127.0.0.1:9000",
      "required": false
    },
    "relay": {
      "provider": "coturn",
      "enabled": false,
      "endpoint": "turn:127.0.0.1:3478",
      "required": false
    },
    "speech_to_text": {
      "provider": "whisper.cpp",
      "enabled": false,
      "endpoint": "http://127.0.0.1:8088",
      "required": false
    },
    "inference": {
      "enabled": false,
      "default_provider": "none",
      "allow_queued_fallback": true,
      "prefer_gpu": true,
      "ollama": {
        "provider": "ollama",
        "enabled": false,
        "endpoint": "http://127.0.0.1:11434",
        "required": false
      },
      "llama_cpp": {
        "provider": "llama.cpp",
        "enabled": false,
        "endpoint": "http://127.0.0.1:8089",
        "required": false
      },
      "compression": {
        "default_strategy": "none",
        "allow_standard": true,
        "allow_experimental_turboquant_compatible": false
      }
    },
    "optional_interop": {
      "provider": "matrix-bridge",
      "enabled": false,
      "required": false
    }
  }
}
