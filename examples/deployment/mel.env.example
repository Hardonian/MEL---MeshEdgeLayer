# Copy to a path outside the repo and chmod 600. Source before systemd or docker-compose.

# MEL_BIND_API=127.0.0.1:8080
# MEL_DATA_DIR=/var/lib/mel/data
# MEL_DB_PATH=/var/lib/mel/data/mel.db

# MEL_AUTH_ENABLED=true
# MEL_SESSION_SECRET=replace-with-long-random-secret
# MEL_UI_USER=operator
# MEL_UI_PASSWORD=replace-with-strong-password

# Comma-separated API keys for automation (requires auth.enabled)
# MEL_AUTH_API_KEYS=key-one-replace-me,key-two-replace-me

# Optional: named profile under configs/profiles/
# MEL_CONFIG_PROFILE=guarded

# Optional self-hosted comms hub dependencies.
# MEL_MINIO_ROOT_USER=mel
# MEL_MINIO_ROOT_PASSWORD=replace-me
# MEL_TURN_USER=mel
# MEL_TURN_PASSWORD=replace-me

# Optional local AI providers (base MEL does not require these).
# MEL_PLATFORM_INFERENCE_ENABLED=false
# MEL_PLATFORM_INFERENCE_DEFAULT_PROVIDER=none
# MEL_PLATFORM_INFERENCE_OLLAMA_ENABLED=false
# MEL_PLATFORM_INFERENCE_LLAMA_CPP_ENABLED=false
