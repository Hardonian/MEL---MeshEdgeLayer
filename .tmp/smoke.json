{
  "bind": {
    "api": "127.0.0.1:8080",
    "metrics": "",
    "allow_remote": false
  },
  "auth": {
    "enabled": false,
    "session_secret": "12e14ff0de9d50f879cf1d3f65bb3b032f8974a8a24586fe9b897c0d11f76f58",
    "ui_user": "admin",
    "ui_password": "change-me",
    "allow_insecure_remote": false
  },
  "storage": {
    "data_dir": ".tmp/data",
    "database_path": ".tmp/data/mel.db",
    "encryption_key_env": "MEL_STORAGE_KEY",
    "encryption_required": false
  },
  "logging": {
    "level": "info",
    "format": "json"
  },
  "retention": {
    "enabled": true,
    "messages_days": 30,
    "telemetry_days": 30,
    "audit_days": 90,
    "precise_position_days": 7
  },
  "privacy": {
    "store_precise_positions": false,
    "mqtt_encryption_required": true,
    "map_reporting_allowed": false,
    "redact_exports": true,
    "trust_list": []
  },
  "transports": [],
  "features": {
    "web_ui": true,
    "metrics": false,
    "ble_experimental": false
  },
  "rate_limits": {
    "http_rps": 20,
    "transport_reconnect_seconds": 10
  },
  "intelligence": {
    "scoring": {
      "anomaly_windows_seconds": [
        60,
        300,
        900
      ],
      "reason_weights": {
        "decode_failure": 5,
        "handler_rejection": 6,
        "malformed_frame": 5,
        "malformed_publish": 5,
        "rejected_publish": 6,
        "rejected_send": 6,
        "retry_threshold_exceeded": 30,
        "stream_failure": 8,
        "subscribe_failure": 8,
        "timeout_failure": 10,
        "timeout_stall": 5,
        "topic_mismatch": 3
      },
      "dead_letter_penalty": 25,
      "historical_dead_letter_weight": 5,
      "residual_penalty_cap": 15,
      "active_episode_penalty": 5,
      "active_episode_penalty_cap": 25,
      "observation_drop_base_penalty": 6,
      "observation_drop_step_penalty": 3,
      "observation_drop_penalty_cap": 30,
      "runtime_retrying_penalty": 12,
      "runtime_failed_penalty": 20,
      "heartbeat_penalty_120_seconds": 10,
      "heartbeat_penalty_300_seconds": 20,
      "heartbeat_penalty_900_seconds": 30
    },
    "alerts": {
      "minimum_state_duration_seconds": 30,
      "cooldown_seconds": 90,
      "recovery_score_healthy": 93,
      "recovery_score_degraded": 78,
      "recovery_score_unstable": 45
    },
    "retention": {
      "health_snapshot_days": 14,
      "health_snapshot_max_rows": 50000,
      "prune_every_seconds": 21600
    },
    "queries": {
      "default_limit": 50,
      "max_limit": 500
    }
  },
  "control": {
    "mode": "advisory",
    "emergency_disable": false,
    "allowed_actions": [
      "restart_transport",
      "resubscribe_transport",
      "backoff_increase",
      "backoff_reset",
      "temporarily_deprioritize_transport",
      "temporarily_suppress_noisy_source",
      "clear_suppression",
      "trigger_health_recheck"
    ],
    "max_actions_per_window": 8,
    "cooldown_per_target_seconds": 300,
    "require_min_confidence": 0.75,
    "allow_mesh_level_actions": false,
    "allow_transport_restart": false,
    "allow_source_suppression": false,
    "action_window_seconds": 900,
    "restart_cap_per_window": 2,
    "max_queue": 32,
    "action_timeout_seconds": 10,
    "retention_days": 14
  },
  "strict_mode": false
}
